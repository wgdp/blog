---
import "../styles/global.css" 
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Ogp } from '../types/Ogp';
import { UIDOLA_THUMBNAIL } from '../util/const';

const { url } = Astro.props;
const ogp:Ogp = {
    title: "息絶えた雑記",
    description: "息絶えた雑記 Gallery",
    thumbnail: UIDOLA_THUMBNAIL,
    url: url,
    pageType: "website"
}
---

<html lang="ja">
  <Head ogp={ogp} />
  <body class="antialiased bg-white text-nord-0 flex flex-col min-h-screen">
    <Header />
    <main class="container mx-auto flex-grow">
      <div class="mx-auto w-full px-6 xs:px-7 sm:px-10 max-w-screen-md">
        <div class="flex justify-center mt-32">
          <h1 class="text-7xl text-nord-1 font-normal">Gallery</h1>
        </div>
        <div class="text-4xl flex flex-col justify-center my-28 leading-relaxed">
          <p class="mx-auto">このページは準備中です</p>
        </div>
      </div>
    </main>
    <Footer />
	</body>
</html>
